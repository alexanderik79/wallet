// tsconfig.json
{
  "compilerOptions": {
    "target": "ESNext",          /* Specify the ECMAScript target version: 'ES3' (default), 'ES5', 'ES2015', 'ES2016', 'ES2017', 'ES2018', 'ES2019', 'ES2020', 'ES2021', 'ES2022', 'ESNext'. */
    "module": "ESNext",          /* Specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015', 'es2020', 'ESNext'. */
    "jsx": "react-jsx",          /* Specify JSX code generation: 'preserve', 'react-native', 'react', 'react-jsx', 'react-jsxdev'. */
    "strict": true,              /* Enable all strict type-checking options. Highly recommended! */
    "esModuleInterop": true,     /* Emit additional JavaScript to ease support for importing CommonJS modules. This enables 'allowSyntheticDefaultImports' for type compatibility. */
    "skipLibCheck": true,        /* Skip type checking all .d.ts files. */
    "forceConsistentCasingInFileNames": true, /* Ensure that casing is preserved when referencing modules. */
    "lib": ["DOM", "DOM.Iterable", "ESNext"], /* Specify a list of library files to be included in the compilation. */
    "allowJs": true,             /* Allow JavaScript files to be compiled. Useful for gradual migration. */
    "noEmit": true,              /* Do not emit output JavaScript and .d.ts files. (Typically handled by build tools like Webpack/Vite) */
    "resolveJsonModule": true,   /* Allow importing .json files as modules. */
    "isolatedModules": true,     /* Ensure that each file can be safely transpiled without relying on other files. */
    "moduleResolution": "node",  /* Specify how modules are resolved. */
    "allowSyntheticDefaultImports": true /* Allow default imports from modules with no default export. This is usually enabled by esModuleInterop. */
  },
  "include": [
    "src",                       /* Specify an array of filenames or patterns to include in the program. */
    "src/**/*.ts",               /* Include all .ts files within the src directory and its subdirectories. */
    "src/**/*.tsx"               /* Include all .tsx files within the src directory and its subdirectories. */
  ],
  "exclude": [
    "node_modules"               /* Specify an array of file patterns to exclude from the compilation. */
  ]
}